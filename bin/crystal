#!/usr/bin/env ruby

require_relative '../lib/astral_verse'

relic_path = nil

if ARGV.empty?
  # Check if we have a cached relic
  last = AstralVerse::LastRelicCache.last_relic

  if last
    puts "🔮 A previous relic lingers in memory..."
    puts "   #{last}"
    puts "   Press [Y] to reattune, [N] to browse, or [Q] to quit"
    puts ""
    print "Choice [y/n/q]: "
    choice = $stdin.gets&.strip&.downcase

    case choice
    when 'y', 'yes'
      relic_path = last
    when 'q', 'quit'
      exit 0
    else
      # Fall through to browser
    end
  end

  unless relic_path
    puts "🔮 Opening the Relic Explorer..."
    require_relative '../lib/astral_verse/ui/file_browser'
    browser = AstralVerse::UI::FileBrowser.new(AstralVerse::LastRelicCache.last_dir)
    browser.show

    if browser.selected_path
      relic_path = browser.selected_path
      AstralVerse::LastRelicCache.save_relic(relic_path)
    else
      puts "❌ No relic chosen. The vault remains sealed."
      exit 0
    end
  end
else
  relic_path = ARGV[0]

  unless File.exist?(relic_path)
    puts "The relic '#{relic_path}' was not found in the mortal realm."
    exit 1
  end

  AstralVerse::LastRelicCache.save_relic(relic_path)
end

stone = AstralVerse::ScryingStone.new
stone.absorb_codex(relic_path)

puts "The Scrying Stone attunes to the relic..."
puts "   #{relic_path}"
puts "Press SPACE to suspend/resume the vision."
puts "Press R to re-attune the stone."
puts "Press ESC to shatter the crystal and return."
puts ""

stone.awaken

puts ""
puts "✨ The Scrying Stone has been sealed."
