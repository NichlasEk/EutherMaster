#!/usr/bin/env ruby

require 'rbconfig'

if defined?(RubyVM::YJIT) && RubyVM::YJIT.respond_to?(:enable) && !RubyVM::YJIT.enabled?
  RubyVM::YJIT.enable
  puts "⚡ Ruby YJIT enabled for emulator hot paths"
end

# ── Wayland / HiDPI Setup ─────────────────────────────
# Prefer the compositor-native SDL backend. The UI now uses actual window
# dimensions, so native Wayland's logical coordinates are what we want.
if ENV['WAYLAND_DISPLAY'] || ENV['XDG_SESSION_TYPE'] == 'wayland'
  ENV['SDL_VIDEODRIVER'] ||= ENV.fetch('ASTRAL_SDL_BACKEND', 'wayland')
  puts "🌊 Wayland session detected — using SDL #{ENV['SDL_VIDEODRIVER']} backend"
end

require_relative '../lib/astral_verse'

puts "═" * 50
puts "   🔮 A S T R A L V E R S E"
puts "═" * 50
puts

loop do
  stone = AstralVerse::ScryingStone.new
  armed_relic = AstralVerse::LastRelicCache.last_relic
  if armed_relic
    begin
      stone.absorb_codex(armed_relic)
    rescue => e
      puts "⚠️ Could not arm cached relic: #{e.message}"
    end
  end

  begin
    require_relative '../lib/astral_verse/ui/crystal_window'
    window = AstralVerse::CrystalWindow.new(stone)
    window.show

    # After window closes, check what user wants
    if window.needs_pick?
      puts "📂 Opening Relic Explorer..."

      require_relative '../lib/astral_verse/ui/file_browser'
      browser = AstralVerse::UI::FileBrowser.new(AstralVerse::LastRelicCache.last_dir)
      browser.show

      if browser.selected_path
        AstralVerse::LastRelicCache.save_relic(browser.selected_path)
        puts "💎 Armed relic: #{File.basename(browser.selected_path)}"
        exec({ 'ASTRAL_RESTARTED_AFTER_PICK' => '1' }, RbConfig.ruby, $PROGRAM_NAME, *ARGV)
      else
        puts "❌ No relic selected."
        break
      end
    elsif window.needs_start?
      # Start was clicked but no ROM loaded yet
      puts "⚠️ No relic armed. Use Open to select one."
      next
    else
      # User pressed ESC without requesting anything
      break
    end
  rescue Interrupt
    puts ""
    puts "✨ Interrupted by cosmic forces."
    break
  rescue => e
    puts ""
    puts "💥 A rift in the astral veil!"
    puts "   #{e.class}: #{e.message}"
    puts e.backtrace.first(3).map { |l| "   #{l}" }.join("\n")
    break
  end
end

puts ""
puts "👋 The Scrying Stone has been sealed."
